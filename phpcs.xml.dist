<?xml version="1.0"?>
<ruleset name="WpApp Coding Standards">
	<description>WordPress coding standards for WpApp framework</description>

	<!-- Check the /src directory -->
	<file>./src</file>

	<!-- Exclude vendor directory if it exists -->
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>

	<!-- Show progress and sniff codes -->
	<arg value="ps"/>

	<!-- Show colors in output -->
	<arg name="colors"/>

	<!-- Use WordPress-Extra ruleset -->
	<rule ref="WordPress-Extra">
		<!-- Allow short array syntax -->
		<exclude name="Generic.Arrays.DisallowShortArraySyntax"/>
		<exclude name="Universal.Arrays.DisallowShortArraySyntax"/>

		<!-- Disable file comment requirement -->
		<exclude name="Squiz.Commenting.FileComment"/>

		<!-- This library uses spaces and short arrays consistently. -->
		<exclude name="Generic.WhiteSpace.DisallowSpaceIndent"/>

		<!-- Keep the standards focused on fixable formatting for now. -->
		<exclude name="Squiz.Commenting"/>
		<exclude name="WordPress.Files.FileName"/>
		<exclude name="WordPress.Security"/>
		<exclude name="WordPress.PHP.DevelopmentFunctions"/>
		<exclude name="WordPress.PHP.StrictInArray"/>
		<exclude name="WordPress.PHP.YodaConditions"/>
		<exclude name="WordPress.WP.EnqueuedResources"/>
		<exclude name="Universal.NamingConventions.NoReservedKeywordParameterNames"/>
		<exclude name="Generic.CodeAnalysis"/>
	</rule>

	<!-- Use WordPress-Docs for documentation standards -->
	<rule ref="WordPress-Docs">
		<exclude name="Squiz.Commenting"/>
	</rule>

	<!-- Use WordPress-Core for core standards -->
	<rule ref="WordPress-Core">
		<exclude name="Generic.Arrays.DisallowShortArraySyntax"/>
		<exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
		<exclude name="Generic.WhiteSpace.DisallowSpaceIndent"/>
		<exclude name="Squiz.Commenting"/>
		<exclude name="WordPress.Files.FileName"/>
		<exclude name="WordPress.Security"/>
		<exclude name="WordPress.PHP.DevelopmentFunctions"/>
		<exclude name="WordPress.PHP.StrictInArray"/>
		<exclude name="WordPress.PHP.YodaConditions"/>
		<exclude name="WordPress.WP.EnqueuedResources"/>
		<exclude name="Universal.NamingConventions.NoReservedKeywordParameterNames"/>
		<exclude name="Generic.CodeAnalysis"/>
	</rule>

	<!-- Check for PHP cross-version compatibility -->
	<config name="testVersion" value="7.4-"/>

	<!-- Allow short array syntax [] instead of array() -->
	<rule ref="Generic.Arrays.DisallowLongArraySyntax"/>

	<!-- Set minimum PHP version -->
	<config name="minimum_supported_wp_version" value="5.0"/>
</ruleset>
